# Website Environment Variables
#
# PUBLIC values go in .env (checked into git)
# SECRET values go in .env.local (gitignored)

# === .env (public, committed) ===
# Firebase Authentication & Firestore - API key is designed to be public
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Optional: only set true if your deploy target proxies /__/auth/* on your custom domain
# VITE_FIREBASE_USE_CUSTOM_AUTH_DOMAIN=true
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
# Optional GA4 tracking ID (public identifier, not a secret)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === .env.local (secrets, NOT committed) ===
# Copy this section to .env.local and fill in values:
GEMINI_API_KEY=your-api-key-here
